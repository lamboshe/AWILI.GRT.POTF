<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Portfolio</title>
</head>
<body>
  <!-- NAVIGATION BAR -->
  <nav>
    <div>
      <h1>Jane Doe</h1>
      <ul>
        <li><a href="#about">About</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <!-- HERO / IMAGE + BIO SECTION -->
    <section id="about">
      <!-- Profile Image -->
      <div>
        <img src="https://i.pravatar.cc/200?img=47" alt="Profile photo of Jane Doe">
      </div>
      <!-- Bio -->
      <div>
        <h2>Hi, I'm Jane 👋</h2>
        <p>Junior Web Developer</p>
        <p>
          I'm a passionate web developer based in Nairobi, Kenya.
          I love building beautiful websites and learning new technologies.
          Currently studying HTML, CSS, and JavaScript to create amazing user experiences.
        </p>
      </div>
    </section>

    <!-- SKILLS SECTION -->
    <section id="skills">
      <div>
        <h2>My Skills</h2>
        <!-- Skills Grid -->
        <div>
          <!-- Skill 1 -->
          <div>
            <div>💻</div>
            <h3>HTML</h3>
            <p>Semantic markup and page structure</p>
          </div>
          <!-- Skill 2 -->
          <div>
            <div>🎨</div>
            <h3>CSS</h3>
            <p>Styling, layout, and animations</p>
          </div>
          <!-- Skill 3 -->
          <div>
            <div>⚡</div>
            <h3>JavaScript</h3>
            <p>Interactive features and logic</p>
          </div>
          <!-- Skill 4 -->
          <div>
            <div>📱</div>
            <h3>Responsive Design</h3>
            <p>Mobile-friendly websites</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT ME SECTION -->
    <section id="contact">
      <h2>Contact Me</h2>
      <form>
        <!-- Name Field -->
        <div>
          <label for="name">Name</label>
          <input id="name" type="text" placeholder="Your name">
        </div>
        <!-- Email Field -->
        <div>
          <label for="email">Email</label>
          <input id="email" type="email" placeholder="you@example.com">
        </div>
        <!-- Message Field -->
        <div>
          <label for="message">Message</label>
          <textarea id="message" rows="4" placeholder="Write your message here..."></textarea>
        </div>
        <!-- Submit Button -->
        <button type="submit">
          Send Message
        </button>
      </form>
    </section>
  </main>

  <!-- FOOTER -->
  <footer>
    <p>© 2025 Jane Doe. Built with ❤️ and Tailwind CSS.</p>
  </footer>
</body>
</html>
